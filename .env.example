# Copy to ".env" and edit as needed. All values have sensible defaults; the defaults
# run fully locally and offline with Ollama, requiring no API keys.

# ----- LLM provider --------------------------------------------------------
# One of: ollama (default, local) | kimi | glm | minimax | groq | gemini
LLM_PROVIDER=ollama

# Local chat model pulled by Ollama (used when LLM_PROVIDER=ollama).
OLLAMA_MODEL=llama3.1:8b

# Optional: override the model id for the active provider (wins over the default).
# e.g. for Kimi: kimi-k2-0905-preview ; for GLM: glm-4.6 ; for MiniMax: MiniMax-M2
# LLM_MODEL=

# ----- API keys for hosted open-source / free-tier providers ---------------
# Only the key for your chosen LLM_PROVIDER is needed.
# Kimi K2 (Moonshot):  https://platform.moonshot.ai  -> API Keys
# MOONSHOT_API_KEY=
# GLM (Zhipu / Z.ai):  https://open.bigmodel.cn
# ZHIPU_API_KEY=
# MiniMax:             https://www.minimaxi.com
# MINIMAX_API_KEY=
# Groq (free tier):    https://console.groq.com/keys
# GROQ_API_KEY=
# Gemini (free tier):  https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# ----- Embeddings ----------------------------------------------------------
# local  = sentence-transformers all-MiniLM-L6-v2, baked into the image, fully offline.
# ollama = nomic-embed-text via Ollama (set PULL_EMBED_MODEL=true so it gets pulled).
EMBED_BACKEND=local
# PULL_EMBED_MODEL=false
# EMBED_MODEL=nomic-embed-text

# ----- Retrieval knobs -----------------------------------------------------
# CHUNK_SEGMENTS=2          # transcript segments grouped per chunk
# CHUNK_STRIDE=1            # 1 => 1-segment overlap between chunks
# TOP_K=8                   # candidates pulled before fusion/rerank
# FINAL_K=3                 # sources returned with the answer
# SCORE_THRESHOLD=0.20      # below => out-of-scope (tuned for MiniLM; re-tune per model)
# USE_RERANKER=false        # true => cross-encoder rerank instead of BM25 fusion
